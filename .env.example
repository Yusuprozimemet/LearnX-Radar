# Copy to .env and fill in. NEVER commit .env.
# In GitHub Actions these come from repo Settings > Secrets, not this file.

# NVIDIA NIM API — primary LLM provider for the pipeline (model set in config.py).
# Get a free key at: build.nvidia.com
NVIDIA_API_KEY=

# Groq API — optional LLM fallback used only when NVIDIA times out (free tier).
# Get a key at: console.groq.com/keys. Leave blank to run NVIDIA-only.
GROQ_API_KEY=

# Telegram delivery (MP3 lesson + summary)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email delivery (Gmail SMTP, daily digest)
GMAIL_APP_PASSWORD=
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# Optional: raises GitHub API rate limit (not required for trending scrape).
GITHUB_TOKEN=

# Optional: Exa neural web search for brief grounding (free key at exa.ai).
# Absent -> grounding falls back to reading the day's own source URLs (keyless).
EXA_API_KEY=

# Optional: the main bot's public @username (without the @) — powers the deep-link
# feedback buttons (trainer "Save results" + lesson star ratings). Absent -> the
# buttons simply aren't rendered.
TELEGRAM_BOT_USERNAME=

# Optional (multi-user Dutch, Phase 1): comma-separated Telegram chat ids of a
# small KNOWN group (~5) who each get their own spaced-repetition schedule and a
# personal cross-day review, sharing ONE generated lesson. The owner is always
# included. Empty -> single-user (unchanged). See plan/personalization.md.
ALLOWED_CHAT_IDS=
# Secret keying each learner's review token (HMAC of the chat id) that names the
# published review/<token>.json. Falls back to the bot token if unset.
REVIEW_TOKEN_SECRET=

# Optional: directory holding per-user state JSON (Dutch memory, radar state, word
# bank). Absent -> defaults to ./storage. In CI it's set to a checkout of the
# private LearnX-Radar-state repo (authorized by the STATE_REPO_TOKEN secret).
STATE_DIR=
